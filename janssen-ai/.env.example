# Janssen AI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Backend URL (used by n8n to call agents API)
BACKEND_URL=http://localhost:3000

# n8n Configuration (optional)
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Database Configuration (PostgreSQL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=janssen_ai
# DB_USER=postgres
# DB_PASSWORD=your_password

# OpenAI Configuration (for LLM integration)
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_MODEL=gpt-4

# CRM Integration (placeholder)
# CRM_API_URL=https://your-crm.com/api
# CRM_API_KEY=your-crm-key

# WhatsApp Business API (placeholder)
# WHATSAPP_API_URL=https://graph.facebook.com/v17.0
# WHATSAPP_PHONE_NUMBER_ID=your-phone-id
# WHATSAPP_ACCESS_TOKEN=your-access-token
